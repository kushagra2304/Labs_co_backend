datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// =========================================
// ENUMS
// =========================================

enum Role {
  admin
  employee
}

enum ProjectStatus {
  in_progress
  completed
  delayed
  near_done
}

enum Priority {
  high
  medium
  low
  critical
}

enum TaskStatus {
  pending
  in_progress
  completed
  overdue
  blocked
  on_hold
}

enum TaskType {
  ADMIN_ASSIGNED
  PERSONAL
}

enum FileType {
  image
  pdf
  doc
  other
}

enum RewardType {
  star
  badge
  bonus
  appreciation
}

enum NotificationType {
  task_assigned
  task_completed
  project_completed
  reward
  reminder
  message
}

enum ActionType {
  task_created
  task_completed
  task_updated
  project_created
  project_updated
  project_completed
  employee_added
  employee_removed
  file_uploaded
  reward_given
  message_sent
}

enum ConversationType {
  DIRECT
  GROUP
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  CLOSED
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

// =========================================
// USER (merged: chat fields + project fields)
// =========================================

model User {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         Role      @default(employee)
  avatarUrl    String?   @map("avatar_url")
  avatarColor  String?   @map("avatar_color")
  phone        String?
  department   String?
  designation  String?
  departmentId String?   @map("department_id") @db.Uuid
  designationId String?   @map("designation_id") @db.Uuid
  joinedDate   DateTime? @map("joined_date")
  isActive     Boolean   @default(true) @map("is_active")

  departmentRel  Department? @relation(fields: [departmentId], references: [id])
  designationRel Designation? @relation(fields: [designationId], references: [id])
  lastSeen     DateTime  @default(now()) @map("last_seen")

  username       String?   @unique @map("username")
  gender         String?
  dateOfBirth    DateTime? @map("date_of_birth")
  employmentType String?   @map("employment_type")
  employeeId     String?   @unique @map("employee_id")

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  // Project module relations
  projectsCreated    Project[]       @relation("ProjectCreatedBy")
  projectMemberships ProjectMember[]
  tasksAssigned      Task[]          @relation("TaskAssignedTo")
  tasksCreated        Task[]         @relation("TaskAssignedBy")
  taskUpdates        TaskUpdate[]
  workLogs           WorkLog[]
  activityLogs       ActivityLog[]
  filesUploaded      File[]
  notifications      Notification[]
  rewardsReceived    Reward[]        @relation("RewardEmployee")
  rewardsGiven       Reward[]        @relation("RewardGivenBy")

  // Chat module relations
  conversationMembers ConversationMember[]
  messages            Message[]
  reactions           MessageReaction[]

  // Attendance module relations
  attendances            Attendance[]
  attendanceRequests     AttendanceRequest[]
  attendanceNotifications AttendanceNotification[]
  auditLogs              AuditLog[]

  @@map("users")
}

// =========================================
// PROJECT MODULE
// =========================================

model Project {
  id              String        @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  status          ProjectStatus @default(in_progress)
  priority        Priority      @default(medium)
  progressPercent Int           @default(0) @map("progress_percent")
  startDate       DateTime?     @map("start_date")
  deadline        DateTime?
  createdById     String?       @map("created_by_id") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  creator  User?           @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  members  ProjectMember[]
  tasks    Task[]
  files    File[]
  workLogs WorkLog[]

  @@map("projects")
}

model ProjectMember {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  roleInProject  String   @default("member") @map("role_in_project")
  assignedAt     DateTime @default(now()) @map("assigned_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@map("project_members")
  @@unique([projectId, userId])
}

model Task {
  id          String     @id @default(uuid()) @db.Uuid
  title       String
  description String?
  projectId   String?    @map("project_id") @db.Uuid
  assignedTo  String?    @map("assigned_to") @db.Uuid
  assignedBy  String?    @map("assigned_by") @db.Uuid
  status      TaskStatus @default(pending)
  priority    Priority   @default(medium)
  dueDate     DateTime?  @map("due_date")
  completedAt DateTime?  @map("completed_at")

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")
  isDeleted Boolean   @default(false) @map("is_deleted")
  estimatedHours Int? @map("estimated_hours")
  taskType TaskType @default(ADMIN_ASSIGNED) @map("task_type")

  project  Project? @relation(fields: [projectId], references: [id])
  assignee User?    @relation("TaskAssignedTo", fields: [assignedTo], references: [id])
  assigner User?    @relation("TaskAssignedBy", fields: [assignedBy], references: [id])

  taskUpdates TaskUpdate[]
  workLogs    WorkLog[]
  files       File[]

  @@map("tasks")
}

model TaskUpdate {
  id              String   @id @default(uuid()) @db.Uuid
  taskId          String   @map("task_id") @db.Uuid
  updatedById     String?  @map("updated_by_id") @db.Uuid
  note            String?
  progressPercent Int?     @map("progress_percent")

  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  task    Task  @relation(fields: [taskId], references: [id])
  updater User? @relation(fields: [updatedById], references: [id])

  @@map("task_updates")
}

model WorkLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  taskId      String?  @map("task_id") @db.Uuid
  projectId   String?  @map("project_id") @db.Uuid
  hoursSpent  Decimal  @map("hours_spent")
  description String?
  logDate     DateTime @map("log_date")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user    User     @relation(fields: [userId], references: [id])
  task    Task?    @relation(fields: [taskId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])

  @@map("work_logs")
}

model ActivityLog {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String?    @map("user_id") @db.Uuid
  actionType  ActionType @map("action_type")
  description String?
  relatedId   String?    @map("related_id") @db.Uuid
  relatedType String?    @map("related_type")

  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

model File {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  fileUrl    String   @map("file_url")
  fileType   FileType @default(other) @map("file_type")
  sizeKb     Int?     @map("size_kb")
  projectId  String?  @map("project_id") @db.Uuid
  taskId     String?  @map("task_id") @db.Uuid
  uploadedBy String?  @map("uploaded_by") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  project  Project? @relation(fields: [projectId], references: [id])
  task     Task?    @relation(fields: [taskId], references: [id])
  uploader User?    @relation(fields: [uploadedBy], references: [id])

  @@map("files")
}

model Notification {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  type        NotificationType
  title       String?
  body        String?
  isRead      Boolean          @default(false) @map("is_read")
  relatedId   String?          @map("related_id") @db.Uuid
  relatedType String?          @map("related_type")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Reward {
  id          String     @id @default(uuid()) @db.Uuid
  employeeId  String     @map("employee_id") @db.Uuid
  givenById   String?    @map("given_by_id") @db.Uuid
  type        RewardType
  message     String?

  createdAt DateTime @default(now()) @map("created_at")

  employee User  @relation("RewardEmployee", fields: [employeeId], references: [id])
  giver    User? @relation("RewardGivenBy", fields: [givenById], references: [id])

  @@map("rewards")
}

// =========================================
// CHAT MODULE (as provided)
// =========================================

model Conversation {
  id            String             @id @default(uuid()) @db.Uuid
  type          ConversationType
  title         String?
  status        ConversationStatus @default(ACTIVE)
  lastMessageAt DateTime           @default(now()) @map("last_message_at")

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  members  ConversationMember[]
  messages Message[]

  @@map("conversations")
}

model ConversationMember {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  lastReadAt     DateTime @default(now()) @map("last_read_at")
  joinedAt       DateTime @default(now()) @map("joined_at")

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  conversation Conversation @relation(fields: [conversationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@map("conversation_members")
  @@unique([conversationId, userId])
}

model Message {
  id             String        @id @default(uuid()) @db.Uuid
  conversationId String        @map("conversation_id") @db.Uuid
  senderId       String        @map("sender_id") @db.Uuid
  content        String?
  messageType    MessageType   @default(TEXT) @map("message_type")
  status         MessageStatus @default(SENT)
  replyToId      String?       @map("reply_to_id") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  conversation Conversation        @relation(fields: [conversationId], references: [id])
  sender       User                @relation(fields: [senderId], references: [id])
  replyTo      Message?            @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]           @relation("MessageReplies")
  attachments  MessageAttachment[]
  reactions    MessageReaction[]

  @@map("messages")
}

model MessageAttachment {
  id            String    @id @default(uuid()) @db.Uuid
  messageId     String    @map("message_id") @db.Uuid
  fileName      String    @map("file_name")
  fileType      String    @map("file_type")
  fileSizeBytes BigInt    @map("file_size_bytes")
  r2ObjectKey   String    @map("r2_object_key")
  cdnUrl        String    @map("cdn_url")
  r2HardDeleted Boolean   @default(false) @map("r2_hard_deleted")
  r2DeletedAt   DateTime? @map("r2_deleted_at")

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  message Message @relation(fields: [messageId], references: [id])

  @@map("message_attachments")
}

model MessageReaction {
  id        String @id @default(uuid()) @db.Uuid
  messageId String @map("message_id") @db.Uuid
  userId    String @map("user_id") @db.Uuid
  emoji     String

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  message Message @relation(fields: [messageId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@map("message_reactions")
  @@unique([messageId, userId, emoji])
}

model Attendance {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  date          DateTime  @db.Date
  status        String
  checkIn       DateTime? @map("check_in")
  checkOut      DateTime? @map("check_out")
  workingHours  Decimal?  @map("working_hours")
  breakDuration Decimal?  @map("break_duration")
  overtime      Decimal?  @map("overtime")
  source        String?
  wifiUsed      String?   @map("wifi_used")
  officeName    String?   @map("office_name")
  deviceInfo    String?   @map("device_info")
  ipAddress     String?   @map("ip_address")
  latitude      Float?
  longitude     Float?
  notes         String?
  adminRemarks  String?   @map("admin_remarks")

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")
  isDeleted Boolean   @default(false) @map("is_deleted")

  user      User      @relation(fields: [userId], references: [id])
  histories AttendanceHistory[]

  @@unique([userId, date])
  @@map("attendances")
}

model AttendanceRequest {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  date         DateTime  @db.Date
  status       String    @default("pending") // pending, approved, rejected
  reason       String
  notes        String?
  adminRemarks String?   @map("admin_remarks")
  approvedAt   DateTime? @map("approved_at")
  approvedBy   String?   @map("approved_by")

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")
  isDeleted Boolean   @default(false) @map("is_deleted")

  user User @relation(fields: [userId], references: [id])

  @@map("attendance_requests")
}

model AttendanceHistory {
  id           String    @id @default(uuid()) @db.Uuid
  attendanceId String    @map("attendance_id") @db.Uuid
  changedBy    String?   @map("changed_by")
  oldStatus    String?   @map("old_status")
  newStatus    String?   @map("new_status")
  oldCheckIn   DateTime? @map("old_check_in")
  newCheckIn   DateTime? @map("new_check_in")
  oldCheckOut  DateTime? @map("old_check_out")
  newCheckOut  DateTime? @map("new_check_out")
  remarks      String?

  createdAt DateTime @default(now()) @map("created_at")

  attendance Attendance @relation(fields: [attendanceId], references: [id])

  @@map("attendance_histories")
}

model OfficeWifi {
  id          String    @id @default(uuid()) @db.Uuid
  officeName  String    @map("office_name")
  ssid        String
  bssid       String    @unique
  staticIp    String?   @map("static_ip")
  floor       String?
  description String?
  isActive    Boolean   @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")
  isDeleted Boolean   @default(false) @map("is_deleted")

  @@map("office_wifis")
}

model AttendancePolicy {
  id                  String   @id @default(uuid()) @db.Uuid
  officeStartTime     String   @default("09:00") @map("office_start_time")
  officeEndTime       String   @default("18:00") @map("office_end_time")
  gracePeriod         Int      @default(15) @map("grace_period")
  lateMinutes         Int      @default(30) @map("late_minutes")
  halfDayRules        String?  @map("half_day_rules")
  minimumWorkingHours Float    @default(8.0) @map("minimum_working_hours")
  maximumWorkingHours Float    @default(12.0) @map("maximum_working_hours")
  overtimeRules       String?  @map("overtime_rules")
  autoCheckout        Boolean  @default(true) @map("auto_checkout")
  workingDays         String   @default("1,2,3,4,5") @map("working_days") // 1=Mon, 7=Sun

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("attendance_policies")
}

model Holiday {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  date        DateTime  @db.Date
  isRecurring Boolean   @default(false) @map("is_recurring")
  description String?

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")
  isDeleted Boolean   @default(false) @map("is_deleted")

  @@map("holidays")
}

model AttendanceNotification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  title     String
  message   String
  isRead    Boolean   @default(false) @map("is_read")
  type      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id])

  @@map("attendance_notifications")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  details   String?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Department {
  id           String        @id @default(uuid()) @db.Uuid
  name         String        @unique
  description  String?
  isActive     Boolean       @default(true) @map("is_active")
  displayOrder Int           @default(0) @map("display_order")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  createdBy    String?       @map("created_by")
  updatedBy    String?       @map("updated_by")
  deletedAt    DateTime?     @map("deleted_at")
  deletedBy    String?       @map("deleted_by")

  designations Designation[]
  users        User[]

  @@map("departments")
}

model Designation {
  id           String      @id @default(uuid()) @db.Uuid
  departmentId String?     @map("department_id") @db.Uuid
  name         String      @unique
  description  String?
  isActive     Boolean     @default(true) @map("is_active")
  displayOrder Int         @default(0) @map("display_order")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  createdBy    String?     @map("created_by")
  updatedBy    String?     @map("updated_by")
  deletedAt    DateTime?   @map("deleted_at")
  deletedBy    String?     @map("deleted_by")

  department   Department? @relation(fields: [departmentId], references: [id])
  users        User[]

  @@map("designations")
}

model TeamFeatureSetting {
  id         String   @id @default(uuid()) @db.Uuid
  featureKey String   @unique @map("feature_key")
  enabled    Boolean  @default(true)
  updatedBy  String?  @map("updated_by")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("team_feature_settings")
}

